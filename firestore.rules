rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Images: Users can read their own images. 
    // Ideally, creation is done via the backend or carefully controlled. 
    // For now, we allow read if owner. 
    // We disallow direct write from client to 'images' if the backend handles it, 
    // BUT the current backend code says "3. Save to main 'images' collection" INSIDE the cloud function.
    // Cloud Functions using Admin SDK bypass rules.
    // If the CLIENT needs to read images, they need this rule.
    match /images/{imageId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // If the client creates image docs directly (e.g. optimistic updates), we might need write.
      // Assuming strict backend generation for now, so NO write allowed from client.
    }

    // Generation Queue: Users can create requests for themselves.
    // They can read their own requests to poll for status.
    match /generation_queue/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Updates (processing -> completed) are done by the backend Admin SDK.
      allow update, delete: if false; 
    }

    // Models: Publicly readable configuration
    match /models/{modelId} {
      allow read: if true;
    }

    // Model Showcase Images: Publicly readable for the gallery
    match /model_showcase_images/{imageId} {
      allow read: if true;
    }
  }
}