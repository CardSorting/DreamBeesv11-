rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Users can read/write their own profile
    match /users/{userId} {
      // Allow read/write if own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Update rules: 
      // 1. Must be own profile
      // 2. If 'username' is being updated:
      //    a. It must NOT have existed before (immutable) OR it must be the same as before
      //    b. It must match regex ^[a-z0-9_]{3,30}$ (sanitization)
      allow write: if request.auth != null && request.auth.uid == userId
                   && (
                     !('username' in request.resource.data) || 
                     (
                       // If checking for immutability:
                       // Either it didn't exist before OR it matches what it was (no change)
                       (!('username' in resource.data) || resource.data.username == request.resource.data.username) &&
                       // And validation:
                       request.resource.data.username.matches('^[a-z0-9_]{3,30}$')
                     )
                   );
      
      match /likes/{likeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /bookmarks/{bookmarkId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /hidden/{hiddenId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /likedApps/{appId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Images: Users can read their own images.
    match /images/{imageId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Allow users to update rating/hidden on their own images
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'hidden']);
    }
    
    // Mockup Items: Publicly readable
    match /mockup_items/{itemId} {
      allow read: if true;
    }

    // Generations: User-generated content (mockups, etc.)
    // Default private, public only if isPublic == true
    match /generations/{generationId} {
      // Public read: only if explicitly marked public
      allow read: if resource.data.isPublic == true;
      
      // Owner read: authenticated user can always read their own
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Create: authenticated user, must own the document
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Update: owner only, restricted to specific fields
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['isPublic', 'likes', 'hidden']);
    }

    // Generation Queue: Users can create requests for themselves.
    match /generation_queue/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Allow users to update rating/hidden on their own requests
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'hidden']);
    }

    // Training Feedback: Users can create/update feedback linked to them
    match /training_feedback/{feedbackId} {
        allow create: if request.auth != null && request.resource.data.asset_pointers.user_id == request.auth.uid;
        allow update: if request.auth != null && resource.data.asset_pointers.user_id == request.auth.uid;
    }

    // Models: Publicly readable configuration
    match /models/{modelId} {
      allow read: if true;
    }

    // Model Showcase Images: Publicly readable for the gallery
    match /model_showcase_images/{imageId} {
      allow read: if true;
    }

    // Video Queue: Users can read/write their own video requests
    match /video_queue/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Videos: Publicly readable for feed (simplified for now)
    match /videos/{videoId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Analysis Queue: Users can read/write their own analysis requests
    match /analysis_queue/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Enhance Queue: Users can read/write their own enhance requests
    match /enhance_queue/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Memes: Public memes are readable by all, private memes only by owner
    match /memes/{memeId} {
      // Public read: only if explicitly marked public
      allow read: if resource.data.isPublic == true;
      
      // Owner read: authenticated user can always read their own
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Create: authenticated user, must own the document
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Update: owner only, restricted to specific fields
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['isPublic', 'likes', 'hidden']);
    }

    // Apps: Publicly readable, writeable by admins only (or no public writes)
    match /apps/{appId} {
      allow read: if true;
      allow update: if request.auth != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']);
      allow write: if false; 
    }
  }
}