rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /likes/{likeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /bookmarks/{bookmarkId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Images: Users can read their own images.
    match /images/{imageId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Allow users to update rating/hidden on their own images
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'hidden']);
    }

    // Generation Queue: Users can create requests for themselves.
    match /generation_queue/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Allow users to update rating/hidden on their own requests
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'hidden']);
    }

    // Training Feedback: Users can create/update feedback linked to them
    match /training_feedback/{feedbackId} {
        allow create: if request.auth != null && request.resource.data.asset_pointers.user_id == request.auth.uid;
        allow update: if request.auth != null && resource.data.asset_pointers.user_id == request.auth.uid;
    }

    // Models: Publicly readable configuration
    match /models/{modelId} {
      allow read: if true;
    }

    // Model Showcase Images: Publicly readable for the gallery
    match /model_showcase_images/{imageId} {
      allow read: if true;
    }

    // Video Queue: Users can read/write their own video requests
    match /video_queue/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Videos: Publicly readable for feed (simplified for now)
    match /videos/{videoId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Analysis Queue: Users can read/write their own analysis requests
    match /analysis_queue/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Enhance Queue: Users can read/write their own enhance requests
    match /enhance_queue/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Apps: Publicly readable, writeable by admins only (or no public writes)
    match /apps/{appId} {
      allow read: if true;
      allow write: if false; // Secured after seeding
    }
  }
}