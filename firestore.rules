rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin())
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['zaps', 'subscriptionStatus', 'role', 'karma', 'isPremium']);
      
      // Allow list for leaderboards/search. Limit increased to 100 for global/league leaderboards.
      allow list: if request.auth != null && request.query.limit <= 100;
      
      // Allow only specific active sub-collections
      match /{coll}/{id} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin())
                          && coll in ['likes', 'bookmarks', 'hidden', 'likedApps', 'follows', 'following', 'followers'];
      }
    }

    // Gaming & Social Systems
    match /league_rooms/{roomId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();

      match /users/{userId} {
        allow read: if request.auth != null;
        // Allow users to update their own document in the league room (e.g. for weeklyExp updates)
        allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    match /community_avatar_pool/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /waitlist/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Worker AI Chats
    match /worker_ai_chats/{chatId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Wallet Ledger (Immutable)
    match /wallet_transactions/{txId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Server-side only
    }

    // Creative Content (Images, Avatars)
    match /images/{imageId} {
      allow read: if request.auth != null || (resource.data.isPublic == true);
      allow write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin()) && (isAdmin() || request.resource.data.userId == request.auth.uid);
    }

    // Public/Feed Content
    match /generations/{jobId} {
      allow read: if request.auth != null || resource.data.isPublic == true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Queues & Processing
    match /generation_queue/{jobId} {
      allow read: if (request.auth != null && (resource.data.userId == request.auth.uid || resource.data.reportCount > 0 || isAdmin()));
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reportCount']));
    }

    match /analysis_queue/{requestId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    match /enhance_queue/{requestId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    // Catalog & Apps Hub
    match /models/{modelId} {
      allow read: if true;
      allow write: if isAdmin(); 
    }
    
    match /model_showcase_images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /showcase_images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /apps/{appId} {
      allow read: if true;
      allow update: if request.auth != null && (isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']));
      allow write: if isAdmin(); 
    }

    match /characters/{characterId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /mockup_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mockups/{mockupId} {
      allow read: if request.auth != null || (resource.data.isPublic == true);
      allow create, update: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin()) && (isAdmin() || request.resource.data.userId == request.auth.uid);
    }

    // Alias mapping for edit lookups
    match /generation_aliases/{aliasId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Stats & Limits
    match /app_stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /rate_limits/{limitId} {
      allow read, write: if isAdmin(); 
    }

    // Twitch Platform Collections
    match /personas/{personaId} {
      allow get, list: if true;
      allow write: if isAdmin(); 
      
      match /shared_messages/{msgId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if isAdmin();
      }

      match /top_supporters/{supporterId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /memories/{userId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow write: if isAdmin();
      }

      match /lore/{loreId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /persona_chat_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // Agent Systems (Firestore Persistence)
    match /agent_capital/{agentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /agent_thoughts/{thoughtId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /agent_macros/{macroId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    match /agent_memory/{memoryId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    // Abuse & Analytics
    match /abuse_violations/{violationId} {
      allow read, write: if isAdmin();
    }

    // Zap Launchpad & Marketplace
    match /zap_derivatives/{derivativeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.ownerId == request.auth.uid || isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['phase', 'metrics', 'marketCap', 'liquidityTotal', 'circulatingSupply', 'currentPrice']));
    }

    match /zap_collections/{collectionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    match /zap_trades/{tradeId} {
      allow read: if true;
      allow write: if false; // Server-side transactions only
    }

    match /zap_ownerships/{ownershipId} {
      allow read: if request.auth != null;
      allow write: if false; 
    }

    match /zap_orders/{orderId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /zap_candles/{candleId} {
      allow read: if true;
      allow write: if false; 
    }
    
    match /zap_ohlc/{ohlcId} {
      allow read: if true;
      allow write: if false;
    }

    match /zap_agent_execution_logs/{logId} {
      allow read: if request.auth != null && isAdmin();
      allow create: if request.auth != null; 
    }

    match /zap_listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    match /zap_swarm_insights/{insightId} {
      allow read: if true;
      allow write: if false; 
    }
    
    match /zap_system_status/{statusId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /zap_governance/{policyId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /zap_agent_reputation/{agentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /zap_agent_signals/{signalId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
    
    match /zap_ownership_snapshots/{snapshotId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /zap_metric_snapshots/{snapshotId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /zap_price_history/{priceId} {
      allow read: if true;
      allow write: if false;
    }

    match /zap_trailing_stops/{stopId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /zap_oco_orders/{orderId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Discord Hive (artbot_) Sovereign Collections
    match /artbot_locks/{discordId} {
      allow read, write: if request.auth != null;
    }
    match /artbot_guilds/{guildId} {
      allow read, write: if request.auth != null;
    }
    match /artbot_generations/{genId} {
      allow read, write: if request.auth != null;
    }
    match /artbot_studios/{studioId} {
      allow read, write: if request.auth != null;
    }
    match /artbot_cooldowns/{userId} {
      allow read, write: if request.auth != null;
    }
    match /artbot_users/{userId} {
      allow read, write: if request.auth != null;
      match /{allPaths=**} {
        allow read, write: if request.auth != null;
      }
    }

    match /artbot_transactions/{txId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /artbot_system/{docId} {
      allow read, write: if isAdmin();
    }
    match /_health/{docId} {
      allow read, write: if request.auth != null;
    }
    match /moderation_logs/{logId} {
      allow read, write: if isAdmin();
    }
    match /reported_generations/{interactionId} {
      allow read, write: if request.auth != null;
    }

  }
}
